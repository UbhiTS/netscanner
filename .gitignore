# ───────────────────────────────────────────────────────────────────────────
#  NetScanner — local data.  NEVER COMMIT THIS.
#  These files contain your real network inventory: IP addresses, MAC
#  addresses, hostnames, device names/notes, vendor info and full scan
#  history. Keeping them out of git is the entire point of this section.
# ───────────────────────────────────────────────────────────────────────────
netscanner_data/
netscanner-data/
**/netscanner_data/
**/netscanner-data/
history/
scan_*.json
devices.json
seen_macs.json
presence.json
baseline.json
events.json
alerts_seen.json
tokens.json
auth.json
# Downloaded IEEE vendor database (large, regenerated on demand)
oui.txt
oui.csv

# ── Secrets / credentials (the app ships none — keep it that way) ────────────
.env
.env.*
*.env
*.pem
*.key
*.pfx
*.p12
*.cer
*.crt
id_rsa*
id_ed25519*
.netrc
secrets.*
*secret*
*credential*
*.token

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
env/
.python-version

